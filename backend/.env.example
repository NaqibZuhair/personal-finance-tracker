PORT=5000
DATABASE_URL="postgresql://postgres:password@localhost:5432/personal_finance_tracker?schema=public"
JWT_SECRET="your-jwt-secret-key"

# WhatsApp Gateway & Bot Multi-User Config
# WA_GATEWAY_URL: URL server Bot WhatsApp (default lokal http://localhost:3000)
WA_GATEWAY_URL="http://localhost:3000"

# VERCEL_SECRET_TOKEN: Token rahasia untuk komunikasi antara Bot WA dan API ini
VERCEL_SECRET_TOKEN="your_super_secret_token_here"

# --- AI FINANCIAL ADVISOR LOAD BALANCER & FAILOVER POOL ---
# Catatan: TIDAK PERLU mengisi variabel MODEL di .env! Model terbaik (Nvidia Nemotron, Gemini 2.5 Flash, Cerebras Llama 3.3, Groq) 
# sudah dikurasi otomatis dalam bentuk array di dalam kode backend (ai.service.ts).
# Anda hanya perlu memasukkan API KEY saja (bisa format koma-dipisahkan ATAU indexed _1, _2, _3, dst):

# 1. Google Gemini AI Keys (Gratis 1.500 req/hari per key!) -> https://aistudio.google.com/
# GEMINI_API_KEYS="AIzaKey1...,AIzaKey2...,AIzaKey3...,AIzaKey4..."
# Atau format indexed:
# GEMINI_API_KEY_1="AIzaKey1..."
# GEMINI_API_KEY_2="AIzaKey2..."

# 2. Cerebras Cloud Keys (Gratis 30 RPM & 1 Juta token/hari - Super Kilat 2000 tok/sec!) -> https://cloud.cerebras.ai/
# CEREBRAS_API_KEYS="csk-Key1...,csk-Key2..."
# Atau format indexed: CEREBRAS_API_KEY_1="csk-..."

# 3. OpenRouter Multiple Keys (Model favorit: Nvidia Nemotron Nano & 340B) -> https://openrouter.ai/
# OPENROUTER_API_KEYS="sk-or-Key1...,sk-or-Key2..."
# Atau format indexed: OPENROUTER_API_KEY_1="sk-or-..."

# 4. Groq Cloud Keys -> https://console.groq.com/
# GROQ_API_KEYS="gsk_Key1...,gsk_Key2..."
