// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
  transfer
}

enum AccountType {
  bank
  ewallet
  cash
  goal
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  name         String
  waPhone      String? @unique
  aiMemory     String?

  accounts              Account[]
  categories            Category[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]
  savingsGoals          SavingsGoal[]
  allocationRoutines    AllocationRoutine[]
  passwordResetOtps     PasswordResetOtp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id           String          @id @default(uuid())
  name         String
  type         TransactionType
  transactions Transaction[]

  userId                String
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, type, userId])
  @@map("categories")
}

model Transaction {
  id              String          @id @default(uuid())
  type            TransactionType
  amount          Decimal         @db.Decimal(12, 2)
  description     String?
  merchantName    String?
  lineItems       Json?
  tags            String[]        @default([])
  transactionDate DateTime

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  accountId String
  account   Account @relation("TransactionFromAccount", fields: [accountId], references: [id], onDelete: Restrict)

  toAccountId String?
  toAccount   Account? @relation("TransactionToAccount", fields: [toAccountId], references: [id], onDelete: Restrict)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([categoryId])
  @@index([transactionDate])
  @@index([accountId])
  @@index([userId])
  @@map("transactions")
}

model Account {
  id              String                 @id @default(uuid())
  name            String
  type            AccountType
  initialBalance  Decimal                @default(0) @db.Decimal(12, 2)
  isActive        Boolean                @default(true)
  includeInTotal  Boolean                @default(true)
  transactionsOut Transaction[]          @relation("TransactionFromAccount")
  transactionsIn  Transaction[]          @relation("TransactionToAccount")
  recurringOut    RecurringTransaction[]  @relation("RecurringFromAccount")
  recurringIn     RecurringTransaction[]  @relation("RecurringToAccount")
  routineItemsOut AllocationRoutineItem[] @relation("RoutineItemFromAccount")
  routineItemsIn  AllocationRoutineItem[] @relation("RoutineItemToAccount")

  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsGoal SavingsGoal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, type, userId])
  @@index([type])
  @@map("accounts")
}

model Budget {
  id     String  @id @default(uuid())
  amount Decimal @db.Decimal(12, 2)
  month  Int
  year   Int

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, month, year])
  @@map("budgets")
}

model SavingsGoal {
  id           String    @id @default(uuid())
  name         String
  targetAmount Decimal   @db.Decimal(12, 2)
  deadline     DateTime?
  color        String?

  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("savings_goals")
}

model RecurringTransaction {
  id          String          @id @default(uuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  frequency   String
  nextRunDate DateTime
  isActive    Boolean         @default(true)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  accountId String
  account   Account @relation("RecurringFromAccount", fields: [accountId], references: [id], onDelete: Restrict)

  toAccountId String?
  toAccount   Account? @relation("RecurringToAccount", fields: [toAccountId], references: [id], onDelete: Restrict)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([nextRunDate])
  @@index([isActive])
  @@index([userId])
  @@map("recurring_transactions")
}

model AllocationRoutine {
  id          String                  @id @default(uuid())
  name        String
  description String?
  items       AllocationRoutineItem[]
  userId      String
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([userId])
  @@map("allocation_routines")
}

model AllocationRoutineItem {
  id          String            @id @default(uuid())
  amount      Decimal           @db.Decimal(12, 2)
  description String?
  routineId   String
  routine     AllocationRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  accountId   String
  account     Account           @relation("RoutineItemFromAccount", fields: [accountId], references: [id], onDelete: Restrict)

  toAccountId String
  toAccount   Account           @relation("RoutineItemToAccount", fields: [toAccountId], references: [id], onDelete: Restrict)

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([routineId])
  @@index([accountId])
  @@index([toAccountId])
  @@map("allocation_routine_items")
}

model PasswordResetOtp {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([otp])
  @@map("password_reset_otps")
}
